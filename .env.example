# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
# Base URL of your application (used for OAuth callbacks, canonical URLs, etc.)
VITE_APP_URL=http://localhost:3000

# Application title (optional, defaults to config)
VITE_APP_TITLE=

# Dashboard URL (for admin panel link)
VITE_DASHBOARD_URL=http://localhost:3002

# Node environment (development, production, test)
NODE_ENV=development

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/portfolio

# Docker Compose alternative:
# Run: docker-compose up -d
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio

# -----------------------------------------------------------------------------
# AUTHENTICATION (Better Auth)
# -----------------------------------------------------------------------------
# https://www.better-auth.com/docs/installation

# Secret key for JWT signing (generate with: openssl rand -hex 64)
# REQUIRED in production
BETTER_AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-hex-64

# Auth base URL (should match VITE_APP_URL)
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OAUTH PROVIDERS
# -----------------------------------------------------------------------------
# Configure OAuth apps and set callback URLs to:
# http://localhost:3000/api/auth/callback/<provider>
# e.g., http://localhost:3000/api/auth/callback/github

# GitHub OAuth
# https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twitter/X OAuth
# https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Facebook OAuth
# https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# EMAIL (Resend)
# -----------------------------------------------------------------------------
# https://resend.com/docs/introduction

# Email address to send from (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Resend API key
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# ERROR TRACKING (Sentry)
# -----------------------------------------------------------------------------
# https://sentry.io
# Sentry provides error tracking and performance monitoring for both client and server.

# Sentry DSN (Data Source Name) - REQUIRED for error tracking
# Get from: Sentry Project Settings → Client Keys (DSN)
# Used by both client and server for error reporting
# Example: https://abc123@o123456.ingest.us.sentry.io/7890123
VITE_SENTRY_DSN=

# Sentry auth token - OPTIONAL (only needed for uploading source maps)
# Get from: Sentry Settings → Auth Tokens
# Create token with: project:releases, project:write scopes
SENTRY_AUTH_TOKEN=

# Sentry organization slug - OPTIONAL (only needed for source maps)
# Get from: Sentry Settings → General Settings
SENTRY_ORG=

# Sentry project slug - OPTIONAL (only needed for source maps)
# Get from: Sentry Project Settings → General Settings
SENTRY_PROJECT=

# Sample Rates (configured in code):
# - Development: 100% (tracesSampleRate: 1.0)
# - Production: 10% (tracesSampleRate: 0.1)
# This reduces costs while maintaining visibility

# -----------------------------------------------------------------------------
# FILE STORAGE (Vercel Blob)
# -----------------------------------------------------------------------------
# https://vercel.com/docs/storage/vercel-blob

# Vercel Blob storage token (for image uploads)
BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Salt for hashing IP addresses (generate with: openssl rand -hex 32)
# Used for anonymous like/view tracking
IP_ADDRESS_SALT=your-random-salt-here-generate-with-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# GITHUB INTEGRATION
# -----------------------------------------------------------------------------
# For fetching GitHub stats and contribution graph

# Your GitHub username
GITHUB_USERNAME=your-github-username
VITE_GITHUB_USERNAME=your-github-username

# GitHub Personal Access Token (optional, but recommended to avoid rate limits)
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo, read:user
GITHUB_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# BOOKMARKS (Raindrop.io)
# -----------------------------------------------------------------------------
# https://developer.raindrop.io

# Raindrop.io access token (for fetching bookmarks)
RAINDROP_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# AI (OpenAI)
# -----------------------------------------------------------------------------
# https://platform.openai.com/docs

# OpenAI API key (for AI features)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# SCHEDULING (Calendly)
# -----------------------------------------------------------------------------
# Public URL to your Calendly booking page
# Used in contact/services sections
CALENDLY_URL=https://calendly.com/your-username

# -----------------------------------------------------------------------------
# ANALYTICS (PostHog)
# -----------------------------------------------------------------------------
# https://posthog.com/docs/libraries/js

# PostHog project API key
VITE_POSTHOG_KEY=

# PostHog API host (default: https://us.i.posthog.com)
VITE_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# VERCEL (Auto-injected in production)
# -----------------------------------------------------------------------------
# These are automatically set by Vercel, no need to configure manually
# VERCEL=1
# VERCEL_URL=your-app.vercel.app
# VERCEL_ENV=production
