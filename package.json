{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "A personal portfolio website built with Tanstack Start and Tailwind CSS.",
  "author": {
    "name": "Tuan Ngo-Hoang",
    "email": "nhtuan314@gmail.com"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --ui=tui",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "check": "biome check .",
    "check:fix": "biome check . --write",
    "format": "biome format .",
    "format:fix": "biome format . --write",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "auth:generate": "pnpm --filter @xbrk/auth generate",
    "db:push": "pnpm --filter @xbrk/db db:push",
    "db:studio": "pnpm --filter @xbrk/db db:studio",
    "db:generate": "pnpm --filter @xbrk/db db:generate",
    "db:migrate": "pnpm --filter @xbrk/db db:migrate",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm run lint:ws",
    "ui-add": "pnpm --filter @xbrk/ui ui-add",
    "deps": "pnpm dlx taze@latest latest -Iwr",
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm exec ultracite fix"
    ]
  },
  "devDependencies": {
    "@base-ui/react": "^1.3.0",
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "shadcn": "^4.1.1",
    "turbo": "^2.9.1",
    "typescript": "catalog:",
    "ultracite": "^7.4.0"
  }
}
